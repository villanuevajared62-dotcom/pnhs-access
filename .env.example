# ===============================
# PNHS Access - Vercel Environment
# ===============================

# Database (PostgreSQL) - Required for Prisma & backend
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:PNHSaccess2026!@YOUR_DB_HOST:5432/pnhs_access"

# Session Secret - Required for secure sessions
# Generate a new one if you want: openssl rand -base64 32
SESSION_SECRET="replace-with-a-long-random-secret"

# Optional: Vercel Blob for serverless file storage
# Only required if your system uses file uploads
# Generate token: vercel blob tokens create
# BLOB_READ_WRITE_TOKEN="your-vercel-blob-token-if-needed"
