# PNHS-ACCESS Environment Variables
# Copy this file to .env.local and update the values

# Database Configuration
# For SQLite (development): file:./dev.db
# For PostgreSQL: postgresql://user:password@localhost:5432/pnhs_access
DATABASE_URL="file:./dev.db"

# Node Environment
NODE_ENV="development"

# Application
NEXT_PUBLIC_APP_NAME=PNHS-ACCESS
NEXT_PUBLIC_APP_URL=http://localhost:3000

# In production, change this to your actual domain
# DATABASE_URL=postgresql://user:password@host:port/db
# NODE_ENV=production
# NEXT_PUBLIC_APP_URL=https://pnhs-access.vercel.app

# Note: For production deployment, you can configure
# environment variables in the Vercel dashboard
