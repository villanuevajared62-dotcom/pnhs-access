generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  role      String   // admin, teacher, student
  name      String
  email     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teacherProfile Teacher?
  studentProfile Student?
}

model Student {
  id         String   @id @default(cuid())
  userId     String   @unique
  studentId  String   @unique
  gradeLevel String
  section    String
  strand     String?
  status     String
  deletedAt  DateTime?

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  enrollments Enrollment[]
  grades      Grade[]
  attendance  Attendance[]
  submissions Submission[]
}

model Teacher {
  id         String   @id @default(cuid())
  userId     String   @unique
  department String?
  deletedAt  DateTime?

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  classes    Class[]
  grades     Grade[]
  attendance AttendanceTeacher[]
  tasks      Task[]
}

model Class {
  id         String   @id @default(cuid())
  name       String
  gradeLevel String
  section    String
  subject    String
  teacherId  String
  schedule   String?
  room       String?
  createdAt  DateTime @default(now())

  teacher     Teacher     @relation(fields: [teacherId], references: [id])
  enrollments Enrollment[]
  attendance  Attendance[]
  assignments Assignment[]
  grades      Grade[]
}

model Enrollment {
  id        String   @id @default(cuid())
  studentId String
  classId   String
  createdAt DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id])
  class   Class   @relation(fields: [classId], references: [id])

  @@unique([studentId, classId])
}

model Grade {
  id        String   @id @default(cuid())
  studentId String
  classId   String
  teacherId String
  quarter   Int
  score     Float
  remarks   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  class   Class   @relation(fields: [classId], references: [id])
  teacher Teacher @relation(fields: [teacherId], references: [id])
}

model Attendance {
  id        String   @id @default(cuid())
  studentId String
  classId   String
  date      DateTime
  status    String   // present, absent, late

  student Student @relation(fields: [studentId], references: [id])
  class   Class   @relation(fields: [classId], references: [id])

  @@unique([studentId, classId, date])
}

model AttendanceTeacher {
  id        String   @id @default(cuid())
  teacherId String
  classId   String
  date      DateTime
  status    String   // present, absent, late

  teacher Teacher @relation(fields: [teacherId], references: [id])
  class   Class   @relation(fields: [classId], references: [id])

  @@unique([teacherId, classId, date])
}

model Assignment {
  id          String   @id @default(cuid())
  title       String
  description String?
  dueDate     DateTime
  status      String   @default("published")
  classId     String
  createdAt   DateTime @default(now())

  class       Class        @relation(fields: [classId], references: [id])
  submissions Submission[]
}

model Submission {
  id           String   @id @default(cuid())
  assignmentId String
  studentId    String
  filePath     String
  submittedAt  DateTime @default(now())
  grade        String?
  feedback     String?

  assignment Assignment @relation(fields: [assignmentId], references: [id])
  student    Student    @relation(fields: [studentId], references: [id])
}

model Task {
  id          String   @id @default(cuid())
  task        String
  deadline    DateTime
  priority    String
  completed   Boolean  @default(false)
  teacherId   String
  createdAt   DateTime @default(now())

  teacher Teacher @relation(fields: [teacherId], references: [id])
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  message   String
  author    String
  audience  String   @default("all")
  createdAt DateTime @default(now())
  deletedAt DateTime?
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actorRole  String?
  action     String
  resource   String
  resourceId String?
  metadata   String?
  createdAt  DateTime @default(now())
}

model Settings {
  id                 String   @id @default(cuid())
  schoolName         String?
  schoolYear         String?
  emailNotifications Boolean  @default(true)
  smsNotifications   Boolean  @default(false)
  updatedAt          DateTime @updatedAt
}
